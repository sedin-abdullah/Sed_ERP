{
  "expo": {
    "name": "SedERP",
    "slug": "sederp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sederp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0b1020",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sedin.sederp"
    },
    "android": {
      "package": "com.sedin.sederp",
      "adaptiveIcon": {
        "backgroundColor": "#0b1020"
      }
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://sed-erp.onrender.com/api/v1",
      "socketUrl": "https://sed-erp.onrender.com"
    }
  }
}
