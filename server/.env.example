# Copy to .env and fill in.
PORT=5100
NODE_ENV=development
# MongoDB Community locally, or a MongoDB Atlas M0 connection string in prod.
MONGODB_URI=mongodb://127.0.0.1:27017/sederp
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Comma-separated allowed origins for CORS + Socket.IO.
CLIENT_URL=http://localhost:5173
# Idempotently upsert demo login accounts on boot (default true). Set false to disable.
SEED_ON_BOOT=true
# MQTT: leave MQTT_URL unset to run the embedded aedes broker (works on Render
# free tier). To use a real Mosquitto locally, set MQTT_URL=mqtt://localhost:1883.
# MQTT_URL=mqtt://localhost:1883
MQTT_BROKER_PORT=1883
